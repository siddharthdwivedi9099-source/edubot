# Frontend environment variables (Vite).
# Copy to .env and adjust as needed.

# In dev, leave unset — vite proxies /api → http://localhost:8000.
# For preview/static-host deployments, set the absolute URL of the backend.
# VITE_API_BASE_URL=https://api.your-school.example.com

# Used by vite.config.js dev proxy only.
# VITE_BACKEND_URL=http://localhost:8000
