# ─────────────────────────────────────────────────────────────
# EduBot — School AI Assistant — Environment Configuration
# Copy this file to `.env` and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── App ──
APP_NAME=EduBot
APP_ENV=development           # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── LLM Provider Selection ──
# Pick ONE primary provider: ollama | openai | anthropic
LLM_PROVIDER=ollama

# Ollama (local, free, recommended for self-hosted schools)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI (cloud)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Anthropic (cloud)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Vector Store (Chroma is local & embedded; default) ──
VECTOR_STORE=chroma           # chroma | pgvector
CHROMA_PERSIST_DIR=./data/chroma

# ── ERP Database ──
# Default uses local SQLite demo DB. For production, set to your school's DB.
# Examples:
#   sqlite+aiosqlite:///./data/demo_school.db
#   mysql+pymysql://user:pass@host:3306/school_erp
#   postgresql+psycopg2://user:pass@host:5432/school_erp
#   mssql+pyodbc://user:pass@host:1433/school_erp?driver=ODBC+Driver+17+for+SQL+Server
ERP_DB_URL=sqlite+aiosqlite:///./data/demo_school.db
ERP_READ_ONLY=true            # safety: block UPDATE/DELETE/DROP
ERP_ALLOWED_TABLES=           # optional comma-separated allowlist; empty = all
ERP_MAX_ROWS=100              # max rows returned per NL→SQL query
ERP_QUERY_TIMEOUT=15          # seconds

# ── WhatsApp via Twilio ──
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Rate limiting ──
RATE_LIMIT_PER_MINUTE=30

# ── Guardrails ──
ENABLE_PII_REDACTION=true
ENABLE_PROFANITY_FILTER=true
ENABLE_OFF_TOPIC_FILTER=true
MAX_INPUT_TOKENS=2000
MAX_OUTPUT_TOKENS=1000
MAX_INPUT_CHARS=4000          # hard cap on user message size in bytes
